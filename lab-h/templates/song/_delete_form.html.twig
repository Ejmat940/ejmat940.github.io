<form method="post" class="d-inline" action="{{ path('app_song_delete', {'id': song.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ song.id) }}">
    <button type="submit" class="btn btn-danger ms-2">Delete</button>
</form>
